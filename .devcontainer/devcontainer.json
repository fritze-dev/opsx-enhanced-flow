// For format details, see https://aka.ms/devcontainer.json
{
  "name": "opsx-enhanced-flow",
  "image": "mcr.microsoft.com/devcontainers/base:noble",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/claude-code:1": {}
  },

  "postCreateCommand": {
    "plugin": "claude plugin marketplace add fritze-dev/opsx-enhanced-flow && claude plugin install opsx@opsx-enhanced-flow"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropics.claude-code",
        "mhutchie.git-graph"
      ],
      "settings": {
        "locale": "en"
      }
    }
  }
}
